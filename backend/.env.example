# Salin file ini menjadi .env dan isi dengan nilai yang sesuai

# Port server (default 3001)
PORT=3001

# AI API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Firebase Admin SDK - path ke service account JSON
# Letakkan file JSON serviceaccount di folder backend/
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Firebase Database URL (cek di Firebase Console > Realtime Database)
FIREBASE_DATABASE_URL=https://smart-class-d26fa-default-rtdb.firebaseio.com

# Firebase Storage Bucket (tanpa gs://)
FIREBASE_STORAGE_BUCKET=smart-class-d26fa.appspot.com

# Secret token untuk autentikasi request dari frontend
# Ganti dengan string acak yang panjang dan susah ditebak!
API_SECRET_TOKEN=ganti_dengan_token_rahasia_kamu_disini

# Allowed origin (URL frontend kamu)
CORS_ORIGIN=http://localhost:3000
