# WEB-OSN Environment Variables
# Copy this to .env.local in the root of the Next.js project

# ============================================================
# FIREBASE (from Firebase Console)
# ============================================================
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=smart-class-d26fa.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://smart-class-d26fa-default-rtdb.asia-southeast1.firebasedatabase.app
NEXT_PUBLIC_FIREBASE_PROJECT_ID=smart-class-d26fa
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=smart-class-d26fa.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=...
NEXT_PUBLIC_FIREBASE_APP_ID=...

# ============================================================
# BACKEND (Pterodactyl / Local)
# ============================================================
# Gunakan proxy lokal /api/backend sehingga tidak ada error Mixed Content (HTTPS -> HTTP)
NEXT_PUBLIC_API_URL=/api/backend

# Token rahasia sama dengan API_SECRET_TOKEN di backend/.env
NEXT_PUBLIC_API_TOKEN=buat_token_rahasia_panjang_kamu_disini

# ============================================================
# VERCEL DEPLOYMENT SETTINGS
# ============================================================
# Tambahkan variabel berikut di Vercel Dashboard agar proxy berfungsi:
# BACKEND_URL=http://154.12.117.59:5094
# API_SECRET_TOKEN=buat_token_rahasia_panjang_kamu_disini
